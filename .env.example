DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/slie_db
REDIS_URL=redis://localhost:6379/0
ENVIRONMENT=development
LOG_LEVEL=INFO
AUTO_CREATE_TABLES=false
RUN_MIGRATIONS_ON_STARTUP=false
SCHEDULER_ENABLED=false
BACKGROUND_WORKERS_ENABLED=false
TELEGRAM_ENABLED=false
LOW_CPU_MODE=true
REDIS_REQUIRED=false
DATABASE_CONNECT_MAX_RETRIES=3
DATABASE_CONNECT_RETRY_DELAY_SECONDS=5
REDIS_CONNECT_TIMEOUT_SECONDS=2
MAX_MESSAGE_ANALYSIS_CONCURRENCY=2
ADMIN_CACHE_TTL_SECONDS=21600
MEMORY_SUMMARY_TRIGGER_MESSAGES=250
MEMORY_SUMMARY_CHECK_INTERVAL=25
SCHEDULER_PUBLIC_REPLY_INTERVAL_MINUTES=10
SCHEDULER_PRIVATE_DM_INTERVAL_MINUTES=10
SCHEDULER_REDDIT_INTERVAL_HOURS=3
SCHEDULER_POWER_UPGRADES_INTERVAL_MINUTES=120
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=18
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
API_ID=
API_HASH=
SESSION_STRING=
PHONE_NUMBER=
